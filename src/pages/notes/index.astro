---
import NoteListPage from "components/notes/NoteListPage.astro";
import { getAllNotes } from "stores/notes";
import { getPageViews } from "utils/umami";
import Root from "layouts/Root.astro";

const notes = await getAllNotes({
	includeDrafts: import.meta.env.DEV,
});

const viewCountEntries = await Promise.all(
	notes.map(async (note) => {
		const views = await getPageViews(`/notes/${note.slug}`);
		return [note.slug, views ?? 0] as const;
	}),
);
const viewCounts = Object.fromEntries(viewCountEntries);
---

<Root
	description="My notes. I write about the things I learn here."
	title="Notes"
	path="/notes"
>
	<NoteListPage {notes} {viewCounts} />
</Root>
